# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/vegan_impact_tracker

# Session Secret (use a strong, random string in production)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# OAuth Configuration (Optional - for Google/Facebook login)
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth  
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Application Configuration
NODE_ENV=development
PORT=5000

# For production deployment, you may also need:
# VITE_API_URL=https://your-backend-domain.com